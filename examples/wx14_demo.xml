<xml xmlns="https://developers.google.com/blockly/xml">
  <block type="v7rc_setup" x="30" y="30">
    <statement name="statement">
      <block type="wx14_begin">
        <value name="UART_ID">
          <shadow type="math_number">
            <field name="NUM">1</field>
          </shadow>
        </value>
        <value name="RX">
          <shadow type="math_number">
            <field name="NUM">5</field>
          </shadow>
        </value>
        <value name="BAUD">
          <shadow type="math_number">
            <field name="NUM">9600</field>
          </shadow>
        </value>
      </block>
    </statement>
  </block>
  <block type="loopProcess" x="30" y="230">
    <statement name="statement">
      <block type="wx14_update">
        <next>
          <block type="controls_if">
            <value name="IF0">
              <block type="wx14_button">
                <field name="BUTTON">LU</field>
              </block>
            </value>
            <statement name="DO0">
              <block type="text_print">
                <value name="TEXT">
                  <shadow type="text">
                    <field name="TEXT">LU pressed</field>
                  </shadow>
                </value>
              </block>
            </statement>
          </block>
        </next>
      </block>
    </statement>
  </block>
</xml>
